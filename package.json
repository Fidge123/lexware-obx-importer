{
  "name": "lexware-obx-importer",
  "private": true,
  "version": "0.2.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:macos": "bun tauri build --bundles app",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "bun test src/obx.spec.ts",
    "test:vitest": "vitest",
    "test:vitest:ui": "vitest --ui",
    "test:all": "bun run test && vitest run",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "sync:r2": "bun run scripts/sync-r2.ts",
    "sync:r2:cleanup": "bun run scripts/sync-r2.ts cleanup",
    "download:r2": "bun run scripts/download-r2.ts"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.9",
    "@tailwindcss/vite": "^4.1.17",
    "@tauri-apps/api": "^2.9.0",
    "@tauri-apps/plugin-fs": "~2.4.4",
    "@tauri-apps/plugin-http": "~2.5.4",
    "@tauri-apps/plugin-opener": "~2.5.2",
    "@tauri-apps/plugin-updater": "~2.9.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.1.17",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.7",
